# Seep Card Game Environment Variables

# JWT Secret for authentication (CHANGE THIS IN PRODUCTION)
JWT_SECRET=your-secret-key-change-in-production

# Server port
PORT=3000

# Postgres connection string
DATABASE_URL=postgres://seep_user:seep_pass@localhost:5432/seep_db

# Node environment
NODE_ENV=development

# Pre-seeded admin account (created on server startup if it doesn't already exist).
# Leave unset to skip seeding — there is no other way to create an admin account.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password